{
  "expo": {
    "name": "ScanProof",
    "slug": "scanproof",
    "version": "1.0.0",
    "scheme": "scanproof",
    "orientation": "portrait",
    "icon": "./AppIcons/playstore.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./AppIcons/playstore.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.scanproof.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./AppIcons/playstore.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "CAMERA"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": [
            {
              "scheme": "scanproof",
              "host": "wallet-callback"
            }
          ]
        }
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./AppIcons/playstore.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera for scanning QR codes"
        }
      ]
    ],
    "extra": {
      "PHANTOM_REDIRECT_URI": "scanproof://wallet-callback",
      "PHANTOM_APP_URL": "https://scanproof.app",
      "SOLANA_CLUSTER": "devnet",
      "SOLANA_RPC_URL": "https://api.devnet.solana.com",
      "IPFS_UPLOAD_URL": "https://api.pinata.cloud/pinning/pinJSONToIPFS",
      "IPFS_GATEWAY_URL": "https://gateway.pinata.cloud/ipfs",
      "PINATA_JWT": ""
    }
  }
}
